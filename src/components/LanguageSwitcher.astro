---
import { type Language } from "@/i18n/translations";

export interface Props {
  lang: Language;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

function getOppositeLanguageUrl(
  currentPath: string,
  currentLang: Language
): string {
  if (currentLang === "es") {
    return currentPath === "/" ? "/en" : `/en${currentPath}`;
  } else {
    return currentPath.replace(/^\/en/, "") || "/";
  }
}

const oppositeUrl = getOppositeLanguageUrl(currentPath, lang);
const isEnglish = lang === "en";
---

<a
  href={oppositeUrl}
  class="lang-switch group relative flex items-center w-[4.5rem] h-8 rounded-full border border-yellow-400/30 hover:border-yellow-400 bg-slate-800/50 hover:bg-slate-700/70 transition-all duration-300 cursor-pointer"
  aria-label={lang === "es" ? "Switch to English" : "Cambiar a Español"}
  title={lang === "es" ? "Switch to English" : "Cambiar a Español"}
>
  <!-- Labels -->
  <span class={`absolute left-2.5 text-xs font-orbitron font-medium transition-colors duration-300 ${isEnglish ? 'text-gray-500' : 'text-yellow-400'}`}>ES</span>
  <span class={`absolute right-2.5 text-xs font-orbitron font-medium transition-colors duration-300 ${isEnglish ? 'text-yellow-400' : 'text-gray-500'}`}>EN</span>

  <!-- Sliding dot -->
  <div class={`absolute top-1 w-6 h-6 rounded-full bg-yellow-400 shadow-[0_0_8px_rgba(250,204,21,0.6)] group-hover:shadow-[0_0_12px_rgba(250,204,21,0.8)] transition-all duration-300 ${isEnglish ? 'left-[calc(100%-1.75rem)]' : 'left-1'}`}></div>
</a>
